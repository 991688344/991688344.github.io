'</span>.<span class="string">'NTM4O'</span>.<span class="string">'w=='</span>.<span class="string">''</span>));</span><br><span class="line"></span><br><span class="line"><span class="keyword">echo</span>(<span class="string">"\n--------"</span>);</span><br><span class="line"></span><br><span class="line"><span class="meta">?&gt;</span></span><br><span class="line">asdzxc</span><br></pre></td></tr></table></figure>
